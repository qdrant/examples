# Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=fashiondb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Qdrant — local Docker instance (default)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=products

# Set to true to use Qdrant Cloud Inference (requires paid cluster).
# false = fastembed runs inference locally via the SDK — no cloud account needed.
CLOUD_INFERENCE=false

# Embedding models
DENSE_MODEL=sentence-transformers/all-MiniLM-L6-v2
SPARSE_MODEL=qdrant/bm25

# Worker settings
QDRANT_SYNC_TTL_SECONDS=2
OUTBOX_BATCH_SIZE=50
OUTBOX_MAX_ATTEMPTS=5