# postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=fashiondb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# qdrant — local Docker instance (default)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=products

# Set to true to use Qdrant Cloud Inference (requires paid cluster).
# false = fastembed runs inference locally — no cloud account needed.
CLOUD_INFERENCE=false

# embedding models
DENSE_MODEL=sentence-transformers/all-MiniLM-L6-v2
SPARSE_MODEL=qdrant/bm25

# kafka/redpanda
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=pgserver.public.products
KAFKA_GROUP_ID=qdrant-sync

# debezium
DEBEZIUM_CONNECT_URL=http://localhost:8083